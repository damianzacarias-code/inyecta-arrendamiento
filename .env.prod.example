# .env.prod.example — Plantilla para docker-compose.prod.yml
#
# Copia a .env.prod y rellena. NUNCA commitees .env.prod (está en
# .gitignore). El archivo es leído por:
#   - docker compose (variables top-level POSTGRES_*)
#   - el contenedor `server` (env_file: .env.prod) — todas las demás

# ── Postgres (sólo lo lee compose para construir DATABASE_URL) ──────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__cambiame__   # 24+ chars random, sin caracteres ambiguos
POSTGRES_DB=inyecta_arrendamiento

# ── Backend ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# JWT — OBLIGATORIO en production. Mínimo 32 chars. Generar con:
#   openssl rand -base64 48
JWT_SECRET=__cambiame_a_un_secret_aleatorio_de_minimo_32_caracteres__
JWT_EXPIRES_IN=24h

# Logging
LOG_LEVEL=info
BITACORA_LOG_GETS=false

# ── CORS ────────────────────────────────────────────────────────────
# Origins permitidos para llamar al backend. CSV. EN PRODUCCIÓN sin
# este valor, el backend bloquea TODO (failsafe).
CORS_ALLOWED_ORIGINS=https://app.inyecta.mx,https://admin.inyecta.mx

# ── CFDI 4.0 ────────────────────────────────────────────────────────
CFDI_PROVIDER=MOCK            # MOCK | FACTURAMA | SW
CFDI_EMISOR_RFC=
CFDI_EMISOR_NOMBRE=
CFDI_EMISOR_REGIMEN=601
CFDI_EMISOR_LUGAR_EXPEDICION=

# Sólo si CFDI_PROVIDER=FACTURAMA
FACTURAMA_USER=
FACTURAMA_PASS=
FACTURAMA_SANDBOX=true

# ── Branding (datos del emisor para PDFs y portal) ──────────────────
BRAND_RAZON_SOCIAL=FSMP Soluciones de Capital, S.A. de C.V., SOFOM, E.N.R.
BRAND_NOMBRE_COMERCIAL=Inyecta
BRAND_DIRECCION=
BRAND_TELEFONOS=
BRAND_EMAIL=
BRAND_WEB=

# ── Datos bancarios para depósitos del arrendatario ─────────────────
# CLABE OBLIGATORIA y de 18 dígitos en producción (Zod la valida).
BANCO_NOMBRE=
BANCO_CLABE=
BANCO_BENEFICIARIO=

# ── Email (notificaciones espejo) ───────────────────────────────────
EMAIL_PROVIDER=NOOP           # NOOP | SMTP | SENDGRID | SES
EMAIL_FROM=
EMAIL_REPLY_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
FRONTEND_BASE_URL=https://app.inyecta.mx
