generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTENTICACIÓN Y USUARIOS
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nombre    String
  apellidos String
  rol       UserRole @default(ANALISTA)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Política de contraseñas (CLAUDE.md §10 — Hardening S1) ────────
  // passwordChangedAt: timestamp del último cambio. Útil para auditoría
  //   PLD y para invalidar tokens emitidos antes (S4 — JWT revocation).
  // mustChangePassword: ADMIN reset → user debe cambiar al próximo login;
  //   también lo seteamos en true para usuarios recién creados.
  passwordChangedAt  DateTime @default(now())
  mustChangePassword Boolean  @default(false)

  // ── MFA / 2FA TOTP (CLAUDE.md §10 — Hardening S5) ─────────────────
  // mfaSecret: base32 del secret TOTP. Cifrado en reposo si MFA_KEK
  //   está set; si no, plaintext (acceso a la BD = compromiso total
  //   de las cuentas igual). Ver lib/mfa.ts.
  // mfaEnabled: solo true después de que el usuario verifica un
  //   primer código TOTP correcto (enrollment confirmado).
  // mfaEnrolledAt: timestamp del enrollment confirmado.
  mfaSecret     String?
  mfaEnabled    Boolean   @default(false)
  mfaEnrolledAt DateTime?

  cotizaciones      Quotation[]
  contratos         Contract[]
  pagosRegistrados  Payment[]             @relation("PaymentsRegistered")
  pagosBorrados     Payment[]             @relation("PaymentsDeletedBy")
  notas             Note[]
  documentosSubidos ExpedienteDocumento[]
  notificaciones    Notificacion[]
  passwordHistory   PasswordHistory[]
  revokedTokens     RevokedToken[]
  mfaBackupCodes    MfaBackupCode[]

  @@map("users")
}

// ── Backup codes para MFA (CLAUDE.md §10 — Hardening S5) ─────────────
// 10 códigos one-time generados al enrollment. Cada uno se usa una sola
// vez (consumedAt) si el usuario pierde su autenticador. Hash bcrypt 12
// — el código en claro NUNCA queda persistido (se muestra una sola vez).
model MfaBackupCode {
  id         String    @id @default(cuid())
  userId     String
  hashedCode String
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@map("mfa_backup_codes")
}

enum UserRole {
  ADMIN
  DIRECTOR
  ANALISTA
  COBRANZA
  OPERACIONES
  LEGAL // CLAUDE.md §2 — recibe notificaciones de SOLICITUD_*
}

// ── Historial de contraseñas ─────────────────────────────────────────
// Guarda las últimas N contraseñas hasheadas (bcrypt) por usuario para
// rechazar reuso. La política mantiene las últimas 5 (configurable en
// passwordPolicy.ts). El hash NUNCA se loggea ni se expone vía API.
model PasswordHistory {
  id             String   @id @default(cuid())
  userId         String
  hashedPassword String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_history")
}

// ── Tokens revocados (logout server-side) ────────────────────────────
// CLAUDE.md §10 — Hardening S4. Los JWTs llevan jti (UUID); cuando un
// usuario hace logout, registramos el jti aquí. requireAuth consulta
// esta tabla (con cache LRU) y rechaza cualquier token cuyo jti esté
// presente.
//
// expiresAt = exp del token original. Un job de limpieza borra los
// registros vencidos (no hace falta retener jtis ya inválidos por
// expiración natural — el verify de jsonwebtoken los rechaza primero).
model RevokedToken {
  jti       String   @id
  userId    String
  expiresAt DateTime
  revokedAt DateTime @default(now())
  reason    String? // 'logout', 'logout_all', 'password_change', etc.

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
  @@map("revoked_tokens")
}

// ============================================================
// CLIENTES
// ============================================================

model Client {
  id                      String     @id @default(cuid())
  tipo                    ClientType
  // Persona Física
  nombre                  String?
  apellidoPaterno         String?
  apellidoMaterno         String?
  curp                    String?
  // Persona Moral
  razonSocial             String?
  // Compartidos
  rfc                     String?    @unique
  email                   String?
  telefono                String? // celular primario (mantenido por compatibilidad)
  telefonoOficina         String?
  // Identidad fiscal y actividad (campos de solicitud CNBV/KYC)
  regimenFiscal           String? // catálogo SAT: 601, 603, 606, 612, 621, 625, 626...
  fiel                    String? // FIEL/e.firma. Obligatorio en PM, opcional PFAE.
  anosAntiguedadActividad Int?
  registroIMSS            String? // registro patronal (PFAE con empleados)
  // Domicilio fiscal
  calle                   String?
  numExterior             String?
  numInterior             String?
  colonia                 String?
  municipio               String?
  ciudad                  String?
  estado                  String?
  pais                    String?    @default("México")
  cp                      String?
  // Domicilio de operación (puede diferir del fiscal)
  calleOp                 String?
  numExteriorOp           String?
  numInteriorOp           String?
  coloniaOp               String?
  municipioOp             String?
  ciudadOp                String?
  estadoOp                String?
  cpOp                    String?
  // PM específicos
  actaConstitutiva        String?
  registroPublico         String?
  representanteLegal      String? // DEPRECATED — usar modelo RepresentanteLegal (1:1)
  fechaConstitucion       DateTime?
  capitalSocial           Decimal?
  folioMercantil          String? // folio del Registro Público de Comercio
  fechaInscripcionRPC     DateTime? // fecha de inscripción de la escritura constitutiva
  // Notario de la escritura constitutiva (PM) — exigido por declaración II-A
  // de los contratos PURO/FIN. Antes solo guardábamos el número de escritura
  // como string libre; ahora desglosado.
  notarioConstNombre      String?
  notarioConstNumero      String?
  notarioConstLugar       String?
  // Metadata
  sector                  String?
  actividadEconomica      String?
  activo                  Boolean    @default(true)
  // Portal del Arrendatario (acceso vía token único)
  portalToken             String?    @unique
  portalUltimoAcceso      DateTime?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  socios                 Shareholder[]
  cotizaciones           Quotation[]
  contratos              Contract[]
  notas                  Note[]
  facturas               Invoice[]
  representanteLegalData RepresentanteLegal?

  @@map("clients")
}

enum ClientType {
  PFAE
  PM
}

// ────────────────────────────────────────────────────────────
// Enums compartidos KYC / solicitud CNBV
// (usados por RepresentanteLegal, Shareholder, Guarantor,
// PerfilTransaccional, DeclaracionPEP).
// ────────────────────────────────────────────────────────────

enum EstadoCivil {
  SOLTERO
  CASADO
}

enum RegimenMatrimonial {
  SEPARACION_BIENES
  SOCIEDAD_CONYUGAL
}

enum SituacionInstalaciones {
  PROPIAS
  RENTADAS
  PAGANDOSE
  FAMILIARES
  COMODATO
  HIPOTECADAS
}

enum Genero {
  M
  F
  OTRO
  NO_ESPECIFICA
}

// NOTA: Los modelos ClientDocument, Guarantor, GarantorDocument,
// ContractGuarantor y ContractDocument fueron reemplazados por
// ExpedienteActor + ExpedienteDocumento (al final del archivo).
// Ver migración: 20260422_expediente_por_actor.

model Shareholder {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Identidad (persona física)
  nombre          String
  apellidoPaterno String
  apellidoMaterno String?
  rfc             String?
  curp            String?
  fiel            String?
  genero          Genero?

  // Si el accionista es persona moral
  razonSocial                    String?
  fechaInscripcionEscrituraConst DateTime?
  folioInscripcionEscrituraConst String?

  // Participación
  porcentaje      Decimal // porcentaje de participación accionaria
  esRepLegal      Boolean @default(false)
  anosExperiencia Int?

  // Nacimiento / nacionalidad
  fechaNacimiento DateTime?
  lugarNacimiento String?
  nacionalidad    String?

  // Estado civil
  estadoCivil        EstadoCivil?
  regimenMatrimonial RegimenMatrimonial?
  nombreConyuge      String?

  // Domicilio particular
  calle                  String?
  numExterior            String?
  numInterior            String?
  colonia                String?
  municipio              String?
  ciudad                 String?
  estado                 String?
  pais                   String?                 @default("México")
  cp                     String?
  situacionInstalaciones SituacionInstalaciones?
  tiempoResidenciaAnos   Int?

  // Contacto
  telefonoFijo    String?
  telefonoCelular String?
  email           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shareholders")
}

// ────────────────────────────────────────────────────────────
// RepresentanteLegal — datos completos del apoderado (PM) o
// del solicitante mismo (PFAE). 1:1 con Client.
// Cubre la sección "DATOS GENERALES DEL REPRESENTANTE/APODERADO
// LEGAL O PERSONA FÍSICA CON ACTIVIDAD EMPRESARIAL" del PDF.
// ────────────────────────────────────────────────────────────
model RepresentanteLegal {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Identidad
  nombre          String
  apellidoPaterno String
  apellidoMaterno String?
  rfc             String?
  curp            String?
  fiel            String?
  genero          Genero?

  // Carrera
  ocupacion       String?
  anosExperiencia Int?

  // Nacimiento / nacionalidad
  fechaNacimiento DateTime?
  lugarNacimiento String?
  nacionalidad    String?

  // Estado civil
  estadoCivil        EstadoCivil?
  regimenMatrimonial RegimenMatrimonial?
  nombreConyuge      String?

  // Domicilio particular
  calle                  String?
  numExterior            String?
  numInterior            String?
  colonia                String?
  municipio              String?
  ciudad                 String?
  estado                 String?
  pais                   String?                 @default("México")
  cp                     String?
  situacionInstalaciones SituacionInstalaciones?
  tiempoResidenciaAnos   Int?

  // Contacto
  telefonoFijo    String?
  telefonoCelular String?
  email           String?

  // Solo PM: inscripción de poderes en RPC
  fechaInscripcionPoderes DateTime?
  folioInscripcionPoderes String?
  // Solo PM: datos completos de la escritura del PODER que acredita al
  // representante legal en el contrato (declaración II-B PURO/FIN).
  // El poder a veces es la misma escritura constitutiva, pero suele ser
  // posterior — por eso se captura aparte.
  poderEscrituraNumero    String?
  poderEscrituraFecha     DateTime?
  poderNotarioNombre      String?
  poderNotarioNumero      String?
  poderNotarioLugar       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("representantes_legales")
}

// ============================================================
// CATÁLOGOS
// ============================================================

model AssetCategory {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  productos   String? // ejemplos de productos (texto)
  tipoSeguro  String? // tipo de cobertura requerida
  requiereGPS Boolean  @default(false)
  activo      Boolean  @default(true)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())

  cotizaciones Quotation[]
  contratos    Contract[]

  @@map("asset_categories")
}

// ============================================================
// COTIZACIONES
// ============================================================

model Quotation {
  id            String         @id @default(cuid())
  folio         String         @unique
  clientId      String?
  client        Client?        @relation(fields: [clientId], references: [id])
  nombreCliente String // puede ser prospecto sin client registrado
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  categoriaId   String?
  categoria     AssetCategory? @relation(fields: [categoriaId], references: [id])

  // Datos del bien
  bienDescripcion String?
  bienMarca       String?
  bienModelo      String?
  bienAnio        Int?
  bienNuevo       Boolean @default(true)
  bienNumSerie    String?

  // Parámetros financieros
  producto     LeaseType
  valorBien    Decimal // sin IVA
  valorBienIVA Decimal? // con IVA (calculado)
  plazo        Int // meses (12-48)
  tasaAnual    Decimal // e.g. 0.36
  nivelRiesgo  RiskLevel @default(A)

  // Montos calculados
  enganche                   Decimal @default(0)
  enganchePorcentaje         Decimal @default(0)
  depositoGarantia           Decimal @default(0)
  depositoGarantiaPct        Decimal @default(0)
  /// Aporte inicial total que el cliente entrega (% de valorBien). El
  /// cotizador lo distribuye automáticamente en `enganche` y
  /// `depositoGarantia` según el nivel de riesgo (lib distribucion.ts).
  /// Default 0 para retro-compat con cotizaciones antes del cambio.
  aporteInicialPct           Decimal @default(0)
  comisionApertura           Decimal @default(0)
  comisionAperturaPct        Decimal @default(0.05)
  comisionAperturaFinanciada Boolean @default(true)
  rentaInicial               Decimal @default(0)
  gpsInstalacion             Decimal @default(0)
  gpsFinanciado              Boolean @default(true)
  /// Clave del GpsProveedor seleccionado al cotizar. null si "Sin GPS".
  /// Se persiste para auditar qué proveedor se usó (los precios pueden
  /// cambiar después en el catálogo).
  gpsProveedor               String?
  seguroAnual                Decimal @default(0)
  seguroFinanciado           Boolean @default(true)
  seguroPendiente            Boolean @default(false) // CLAUDE.md §4.14: si true, no entra en cálculos
  valorResidual              Decimal @default(0)
  valorResidualPct           Decimal @default(0)
  // CLAUDE.md §4.13 — PURO checkbox "Valor residual = depósito en garantía".
  // Cuando es true, valorResidualResuelto = depositoGarantia (el cliente
  // "pierde" el depósito a cambio del bien al final del contrato). El nombre
  // legacy del campo era valorResidualEsComision; renombrado por el operador
  // que clarificó la regla de negocio el 27-04-2026.
  valorResidualEsDeposito    Boolean @default(false)

  // Resultados
  montoFinanciar  Decimal?
  rentaMensual    Decimal?
  rentaMensualIVA Decimal?
  totalRentas     Decimal?
  totalPagar      Decimal?
  ganancia        Decimal?

  // Estado
  estado          QuotationStatus @default(VIGENTE)
  fechaCotizacion DateTime        @default(now())
  vigenciaHasta   DateTime?
  observaciones   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opciones QuotationOption[]
  contrato Contract?

  @@map("quotations")
}

enum LeaseType {
  PURO
  FINANCIERO
}

enum RiskLevel {
  A // bajo - 16%
  B // medio - 21%
  C // alto - 26%
}

enum QuotationStatus {
  VIGENTE
  VENCIDA
  APROBADA
  RECHAZADA
  CONVERTIDA // se convirtió en contrato
}

model QuotationOption {
  id               String    @id @default(cuid())
  quotationId      String
  quotation        Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  nombre           String // "Opción A - Riesgo bajo", etc.
  producto         LeaseType
  nivelRiesgo      RiskLevel
  enganche         Decimal
  rentaInicial     Decimal
  depositoGarantia Decimal
  rentaMensualIVA  Decimal
  valorResidual    Decimal
  totalPagar       Decimal
  ganancia         Decimal
  descripcion      String? // descripción de la estructura

  @@map("quotation_options")
}

// ============================================================
// CONTRATOS
// ============================================================

model Contract {
  id          String         @id @default(cuid())
  folio       String         @unique // e.g. ARR-001-2026
  quotationId String?        @unique
  quotation   Quotation?     @relation(fields: [quotationId], references: [id])
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id])
  userId      String // analista que registró
  user        User           @relation(fields: [userId], references: [id])
  categoriaId String?
  categoria   AssetCategory? @relation(fields: [categoriaId], references: [id])

  // Pipeline
  etapa            ContractStage @default(SOLICITUD)
  etapaFecha       DateTime      @default(now())
  comiteResolucion String? // APROBADO, APROBADO_CONDICIONES, RECHAZADO

  // Datos de la solicitud (página 1 del formato KYC → Nueva Operación)
  lugarSolicitud       String?
  fechaSolicitud       DateTime?
  promotor             String?
  montoSolicitado      Decimal? // monto originalmente solicitado; puede diferir del aprobado
  destinoArrendamiento String?

  // Terceros (del bloque "DATOS COMPLEMENTARIOS" del PDF)
  tercerBeneficiarioExiste Boolean?
  tercerBeneficiarioInfo   String?
  tercerAportanteExiste    Boolean?
  tercerAportanteInfo      String?

  // Datos del bien
  bienDescripcion  String
  bienMarca        String?
  bienModelo       String?
  bienAnio         Int?
  bienNumSerie     String? // serie de maquinaria/equipo
  bienEstado       String? // nuevo/seminuevo
  // Identificación de vehículo (cláusula DÉCIMA SEXTA prohíbe alterar
  // las "características esenciales o de identificación" — son éstas).
  bienColor        String?
  bienPlacas       String?
  bienNIV          String? // VIN/NIV vehicular (17 chars)
  bienMotor        String? // número de motor
  // Lugar de entrega del bien (cláusula TERCERA PURO/FIN). Puede diferir
  // del domicilio fiscal del cliente (entrega directa del proveedor a
  // sucursal, obra, planta, etc.).
  lugarEntregaBien String?
  proveedor        String? // DEPRECATED — usar modelo Proveedor (1:1)

  // Parámetros financieros
  producto      LeaseType
  valorBien     Decimal
  valorBienIVA  Decimal
  plazo         Int
  tasaAnual     Decimal
  tasaMoratoria Decimal? // default: 2x tasa ordinaria
  nivelRiesgo   RiskLevel

  // Montos
  enganche                Decimal @default(0)
  depositoGarantia        Decimal @default(0)
  /// Snapshot del aporte inicial total (% sobre valorBien) elegido al
  /// firmar el contrato. enganche y depositoGarantia se derivan de aquí
  /// vía lib distribucion.ts (cliente) o validación cruzada (server).
  aporteInicialPct        Decimal @default(0)
  comisionApertura        Decimal @default(0)
  rentaInicial            Decimal @default(0)
  gpsInstalacion          Decimal @default(0)
  /// Snapshot del proveedor GPS elegido. null si "Sin GPS".
  gpsProveedor            String?
  seguroAnual             Decimal @default(0)
  seguroPendiente         Boolean @default(false) // CLAUDE.md §4.14
  valorResidual           Decimal @default(0)
  // §4.13 — PURO: residual = depósito en garantía (renombrado 27-04-2026).
  valorResidualEsDeposito Boolean @default(false)
  montoFinanciar          Decimal
  rentaMensual            Decimal
  rentaMensualIVA         Decimal

  // Fechas
  fechaFirma       DateTime?
  fechaInicio      DateTime? // fecha de primera renta
  fechaEntregaBien DateTime?
  fechaVencimiento DateTime?
  fechaTerminacion DateTime?
  // Día del mes en que se paga la renta (cláusula OCTAVA FIN: "cada día
  // XX de mes"). Si null, se infiere del día de fechaInicio.
  diaPagoMensual   Int?

  // Estado del contrato
  estatus           ContractStatus @default(EN_PROCESO)
  motivoTerminacion String?

  // Opción al vencimiento
  opcionVencimiento EndOption?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tipo de titular del expediente (PFAE/PM). Determina qué actores y
  // catálogos de documentos aplican al expediente del contrato. Snapshot
  // del Client.tipo al momento de crear el contrato — un cliente PFAE
  // que se transforma a PM no rompe contratos previos.
  tipoTitular ClientType

  amortizacion   AmortizationEntry[]
  pagos          Payment[]
  seguros        InsurancePolicy[]
  gps            GPSDevice[]
  mantenimientos MaintenanceRecord[]
  notas          Note[]
  stageHistory   StageHistory[]
  facturas       Invoice[]

  // Expediente documental por contrato (Operación, Solicitante,
  // Rep. Legal, Accionista, Avales 1..N, Bien, Formalización).
  actores ExpedienteActor[]

  // Relaciones KYC / solicitud
  perfilTransaccional PerfilTransaccional?
  proveedorData       Proveedor?
  declaracionesPEP    DeclaracionPEP[]

  // Avales (deudores solidarios). El expediente legacy guardaba el
  // aval como ExpedienteActor con datosAdicionales: Json no tipado.
  // El modelo Aval estructura los datos demográficos completos que
  // exigen los contratos (RFC, CURP, domicilio, estado civil + cónyuge).
  avales Aval[]

  // Pagaré (sólo FIN, cláusula DÉCIMA TERCERA). 1:1.
  pagare Pagare?

  @@map("contracts")
}

// ────────────────────────────────────────────────────────────
// PerfilTransaccional — PLD/KYC sección "PERFIL TRANSACCIONAL"
// 1:1 con Contract.
// ────────────────────────────────────────────────────────────
model PerfilTransaccional {
  id         String   @id @default(cuid())
  contractId String   @unique
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  productosQueAdquirira String?
  origenRecursos        String?
  destinoRecursos       String?
  montoMensualRango     MontoRango?
  frecuencia            FrecuenciaTrans?
  numOperacionesRango   NumOpsRango?
  realizaPagosEfectivo  Boolean?
  efectivoMotivos       String? // condicional: solo si realizaPagosEfectivo=true
  efectivoMontoMensual  Decimal? // condicional: solo si realizaPagosEfectivo=true

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("perfil_transaccional")
}

enum MontoRango {
  HASTA_50K
  ENTRE_50K_100K
  MAS_100K
}

enum FrecuenciaTrans {
  DIARIA
  SEMANAL
  QUINCENAL
  MENSUAL
}

enum NumOpsRango {
  UNO_A_TREINTA
  TREINTAIUNO_A_CINCUENTA
  MAS_DE_CINCUENTA
}

// ────────────────────────────────────────────────────────────
// Proveedor del bien (sección "DETALLES PARA LA COMPRA DEL BIEN")
// 1:1 con Contract.
// ────────────────────────────────────────────────────────────
model Proveedor {
  id         String   @id @default(cuid())
  contractId String   @unique
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  nombre         String
  nombreContacto String?
  telefono       String?
  email          String?

  // Identidad fiscal (cláusula SEGUNDA FIN: "LA ARRENDADORA se obliga a
  // adquirir el bien"). Sin RFC no se puede emitir CFDI de compra.
  rfc         String?
  // Domicilio fiscal (para CFDI y cláusula de notificaciones)
  calle       String?
  numExterior String?
  numInterior String?
  colonia     String?
  municipio   String?
  ciudad      String?
  estado      String?
  pais        String? @default("México")
  cp          String?
  // Datos bancarios para dispersión del monto de adquisición
  banco       String?
  clabe       String?
  numCuenta   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("proveedores")
}

// ────────────────────────────────────────────────────────────
// DeclaracionPEP — Persona Políticamente Expuesta (sección
// "DECLARACIONES DEL CLIENTE" del PDF). 1:n con Contract,
// hasta 3 tipos: SOLICITANTE, PARIENTE, SOCIO_ACCIONISTA.
// Todos los campos de detalle son condicionales a esPep=true.
// ────────────────────────────────────────────────────────────
model DeclaracionPEP {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  tipo  PepTipo
  esPep Boolean // Sí/No

  // Condicionales a esPep=true:
  nombre               String? // para PARIENTE (nombre del pariente PEP)
  parentesco           String? // para PARIENTE (relación con el titular)
  dependencia          String?
  puesto               String?
  periodoEjercicio     String?
  principalesFunciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, tipo])
  @@map("declaraciones_pep")
}

enum PepTipo {
  SOLICITANTE
  PARIENTE
  SOCIO_ACCIONISTA
}

enum ContractStage {
  SOLICITUD
  ANALISIS_CLIENTE
  ANALISIS_BIEN
  COMITE
  FORMALIZACION
  DESEMBOLSO
  ACTIVO
}

enum ContractStatus {
  EN_PROCESO // aún en pipeline
  VIGENTE // contrato activo
  VENCIDO // pasó fecha de vencimiento sin formalizar cierre
  TERMINADO // terminación normal
  RESCINDIDO // rescisión por incumplimiento
  REESTRUCTURADO
}

enum EndOption {
  DEVOLUCION
  RENOVACION
  RESCATE // Puro: paga valor residual
  OPCION_COMPRA // Financiero: paga 2% simbólico
}

model StageHistory {
  id          String        @id @default(cuid())
  contractId  String
  contract    Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  etapa       ContractStage
  fecha       DateTime      @default(now())
  observacion String?
  usuarioId   String?

  @@map("stage_history")
}

// ============================================================
// AMORTIZACIÓN
// ============================================================

model AmortizationEntry {
  id           String   @id @default(cuid())
  contractId   String
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  periodo      Int
  fechaPago    DateTime
  saldoInicial Decimal
  intereses    Decimal  @default(0) // solo financiero
  pagoCapital  Decimal  @default(0) // solo financiero
  renta        Decimal
  iva          Decimal
  seguro       Decimal  @default(0)
  pagoTotal    Decimal
  saldoFinal   Decimal

  @@unique([contractId, periodo])
  @@map("amortization_entries")
}

// ============================================================
// PAGOS Y COBRANZA
// ============================================================

model Payment {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  userId     String? // quien registró el pago
  user       User?    @relation("PaymentsRegistered", fields: [userId], references: [id])

  periodo          Int? // número de renta que cubre
  tipo             PaymentType
  fechaPago        DateTime
  fechaVencimiento DateTime?

  montoRenta        Decimal @default(0)
  montoIVA          Decimal @default(0)
  montoSeguro       Decimal @default(0)
  montoMoratorio    Decimal @default(0)
  montoIVAMoratorio Decimal @default(0)
  montoCapitalExtra Decimal @default(0) // abono a capital (financiero)
  montoTotal        Decimal

  diasAtraso    Int     @default(0)
  referencia    String? // referencia bancaria / comprobante
  observaciones String?

  factura Invoice?

  // Soft delete (auditoría PLD): un pago borrado NO se elimina físicamente,
  // se marca con `deletedAt` y queda excluido de los cálculos de saldo.
  // El registro persiste para evidencia ante CNBV/CONDUSEF y para reconstruir
  // historial si la baja fue un error. `deletedBy` apunta al usuario que la
  // ejecutó; `motivoEliminacion` es texto libre opcional (recomendable).
  deletedAt         DateTime?
  deletedBy         String?
  deletedByUser     User?     @relation("PaymentsDeletedBy", fields: [deletedBy], references: [id])
  motivoEliminacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Índices de performance:
  //   (contractId, periodo) — buscar el pago de un periodo concreto
  //     (cobranza /pay-status, conciliación, reportes de morosidad).
  //   (contractId, fechaPago) — listar pagos cronológicos por contrato
  //     (estado de cuenta, portal del arrendatario).
  //   (fechaPago) — reportes de cobranza por rango de fechas.
  //   (deletedAt) — filtros eficientes "WHERE deletedAt IS NULL" cuando
  //     haya volumen significativo de pagos borrados (auditoría).
  @@index([contractId, periodo])
  @@index([contractId, fechaPago])
  @@index([fechaPago])
  @@index([deletedAt])
  @@map("payments")
}

// ============================================================
// CONCILIACIÓN BANCARIA
// ============================================================

model BankStatement {
  id          String    @id @default(cuid())
  banco       String // BBVA, Santander, Banamex, ...
  cuenta      String? // CLABE o nº cuenta
  fileName    String
  fechaInicio DateTime?
  fechaFin    DateTime?
  totalAbonos Decimal   @default(0)
  totalCargos Decimal   @default(0)
  uploadedBy  String?
  createdAt   DateTime  @default(now())

  transacciones BankTransaction[]

  @@map("bank_statements")
}

model BankTransaction {
  id          String        @id @default(cuid())
  statementId String
  statement   BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  fecha       DateTime
  descripcion String
  referencia  String?
  monto       Decimal // positivo = abono (depósito a Inyecta)
  tipo        String // ABONO | CARGO

  // Conciliación
  matched    Boolean   @default(false)
  paymentId  String? // referencia (sin FK estricto)
  matchScore Int? // 0-100 (qué tan confiable fue el match)
  matchedBy  String? // userId o "AUTO"
  matchedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([statementId])
  @@index([matched])
  @@map("bank_transactions")
}

// ============================================================
// FACTURACIÓN ELECTRÓNICA (CFDI 4.0)
// ============================================================

model Invoice {
  id         String   @id @default(cuid())
  // Vínculo
  paymentId  String?  @unique
  payment    Payment? @relation(fields: [paymentId], references: [id])
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])

  // CFDI
  tipo          InvoiceType   @default(INGRESO) // INGRESO / EGRESO / PAGO
  serie         String        @default("A")
  folio         Int
  uuid          String?       @unique // SAT
  fechaTimbrado DateTime?
  status        InvoiceStatus @default(BORRADOR)

  // Importes
  subtotal    Decimal
  iva         Decimal @default(0)
  retenciones Decimal @default(0)
  total       Decimal

  // Datos receptor (snapshot al momento de timbrado)
  rfcReceptor    String
  nombreReceptor String
  usoCfdi        String @default("G03") // Gastos en general
  metodoPago     String @default("PUE")
  formaPago      String @default("03") // Transferencia
  regimenFiscal  String @default("601")

  // Archivos
  xmlUrl String?
  pdfUrl String?

  // Cancelación
  motivoCancelacion String?
  fechaCancelacion  DateTime?

  // Provider
  provider String @default("MOCK") // MOCK | FACTURAMA | SW

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceType {
  INGRESO
  EGRESO
  PAGO
}

enum InvoiceStatus {
  BORRADOR
  TIMBRADO
  CANCELADO
  ERROR
}

enum PaymentType {
  RENTA_ORDINARIA
  RENTA_ADELANTADA
  ABONO_CAPITAL // solo financiero
  LIQUIDACION_ANTICIPADA
  MORATORIO
  RENTA_EXTRAORDINARIA // post-vencimiento sin formalizar
  ENGANCHE
  DEPOSITO_GARANTIA
  COMISION_APERTURA
  SEGURO
  GPS
  OTRO
}

// ============================================================
// SEGUROS
