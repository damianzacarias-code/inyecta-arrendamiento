// ============================================================
// BITÁCORA — auditoría PLD (cumplimiento regulatorio SOFOM)
// Todas las operaciones POST/PATCH/PUT/DELETE quedan registradas
// con usuario, IP, payload y timestamp para inspección de la CNBV.
// ============================================================

// ============================================================
// NOTIFICACIONES IN-APP
// CLAUDE.md §9 T9 — notificar siempre a ADMIN + ejecutivo;
// si la acción es SOLICITUD_*, también a LEGAL.
// ============================================================

model Notificacion {
  id          String   @id @default(cuid())
  userId      String                          // destinatario
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo        String                          // ej: "SOLICITUD_CREADA", "PAGO_REGISTRADO", "CONTRATO_VENCIDO"
  titulo      String                          // texto corto para listado
  mensaje     String                          // descripción legible
  entidad     String?                         // ej: "Contract", "Payment", "Quotation"
  entidadId   String?                         // id del recurso relacionado
  url         String?                         // deep-link al detalle (opcional)
  leida       Boolean  @default(false)
  leidaAt     DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, leida])
  @@index([userId, createdAt])
  // Composite (userId, leida, createdAt): combina las dos anteriores en
  // una sola lectura de índice para la query estrella de la campana
  // ("últimas N no leídas del usuario X ordenadas por fecha desc").
  @@index([userId, leida, createdAt])
  @@index([entidad, entidadId])
  @@map("notificaciones")
}

model Bitacora {
  id          String   @id @default(cuid())
  requestId   String?                       // X-Request-ID propagado por requestId middleware (correlación con logs pino)
  usuarioId   String?
  usuarioEmail String?            // snapshot del email al momento del evento
  usuarioRol  String?             // snapshot del rol
  metodo      String              // GET, POST, PATCH, PUT, DELETE
  ruta        String              // ej: "/api/contracts/abc123"
  entidad     String?             // ej: "Contract", "Payment"
  entidadId   String?             // id del recurso afectado (si aplica)
  accion      String              // verbo descriptivo: CREATE, UPDATE, DELETE, LOGIN, etc.
  payloadJson Json?               // body sanitizado (sin password ni tokens)
  responseStatus Int?             // 200, 201, 4xx, 5xx
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([usuarioId])
  @@index([entidad, entidadId])
  @@index([createdAt])
  // Composite (usuarioId, createdAt): timeline por usuario sin scan.
  // Útil para "actividad del usuario X en los últimos 30 días" del visor
  // de bitácora (filtros usuarioId + rango de fechas).
  @@index([usuarioId, createdAt])
  // Lookup directo por correlation-id desde un log estructurado de pino.
  @@index([requestId])
  @@map("bitacora")
}

// ============================================================
// EXPEDIENTE DOCUMENTAL POR CONTRATO
// ------------------------------------------------------------
// Estructura por ACTORES del expediente, basada en los checklists
// oficiales de Inyecta (PFAE y PM). Cada contrato tiene su propio
// expediente — los actores y documentos cuelgan del contrato, NO
// del cliente. Esto significa que un cliente con varios contratos
// tendrá un expediente independiente por operación.
//
// Reemplaza por completo a los modelos legacy:
//   - ClientDocument
//   - GarantorDocument
//   - ContractDocument
//   - Guarantor
//   - ContractGuarantor
//
// Actores fijos (únicos por contrato): OPERACION, SOLICITANTE,
// REPRESENTANTE_LEGAL (PM), PRINCIPAL_ACCIONISTA (PM), BIEN_ARRENDADO,
// FORMALIZACION.
// Actores dinámicos: AVAL (0..N por contrato, distinguidos por orden
// 1, 2, 3...). Cada AVAL puede ser PF o PM, lo cual cambia el catálogo
// esperado de documentos.
//
// Los catálogos de tipos de documento por actor viven en código
// (server/src/services/expedienteCatalogs.ts) — son metadatos/checklist
// visual, NO bloquean la subida de archivos libres.
// ============================================================

enum ActorTipo {
  OPERACION             // documentos del proceso de originación
  SOLICITANTE           // titular del contrato (PFAE o PM)
  REPRESENTANTE_LEGAL   // único, solo si tipoTitular = PM
  PRINCIPAL_ACCIONISTA  // único, solo si tipoTitular = PM
  AVAL                  // 0..N obligados solidarios por contrato
  BIEN_ARRENDADO        // factura, avalúo, póliza, REPUVE, RUG, etc.
  FORMALIZACION         // resolución, contrato firmado, RUG/RPP
}

enum ActorSubtipo {
  PF
  PM
}

enum DocumentoEstatus {
  PENDIENTE
  VALIDADO
  RECHAZADO
}

model ExpedienteActor {
  id              String        @id @default(cuid())
  contractId      String
  contract        Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tipo            ActorTipo
  subtipo         ActorSubtipo? // requerido cuando tipo = AVAL; null en los demás
  orden           Int           @default(1) // 1 para fijos; 1..N para AVAL
  nombre          String?       // nombre completo o razón social del actor
  rfc             String?       // opcional — para actores con identidad propia
  datosAdicionales Json?        // dirección, teléfono, % accionario, parentesco, etc.
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  documentos      ExpedienteDocumento[]

  // Unicidad: para actores fijos (orden=1) garantiza un solo
  // OPERACION/SOLICITANTE/REP_LEGAL/etc. por contrato. Para AVAL,
  // orden distingue Aval 1, Aval 2, etc.
  @@unique([contractId, tipo, orden])
  @@index([contractId])
  @@map("expediente_actores")
}

model ExpedienteDocumento {
  id             String           @id @default(cuid())
  actorId        String
  actor          ExpedienteActor  @relation(fields: [actorId], references: [id], onDelete: Cascade)
  // Clave del catálogo del actor (ej. "INE", "ACTA_CONSTITUTIVA")
  // o null si el promotor lo subió como "Libre/Sin clasificar".
  tipoDocumento  String?
  // Nombre original del archivo subido (para mostrar en UI).
  nombreArchivo  String
  // URL pública relativa (servida por express.static, ej. /uploads/expedientes/...).
  archivoUrl     String
  // Físico en oficina y digital en sistema son INDEPENDIENTES.
  // tieneDigital se setea automáticamente al subir; tieneFisico se
  // marca manualmente cuando llega la copia en papel.
  tieneFisico    Boolean          @default(false)
  tieneDigital   Boolean          @default(true)
  estatus        DocumentoEstatus @default(PENDIENTE)
  notas          String?
  fechaSubida    DateTime         @default(now())
  subidoPor      String?
  subidoPorUser  User?            @relation(fields: [subidoPor], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([actorId])
  @@index([actorId, tipoDocumento])
  @@map("expediente_documentos")
}

// ============================================================
// SECUENCIAS DE FOLIO — atómicas, una fila por (scope, year)
// ============================================================
// Reemplaza el patrón inseguro `count + 1` que tenía race condition
// cuando dos usuarios firmaban contratos en el mismo segundo (los dos
// obtenían el mismo count → segundo INSERT fallaba con P2002).
//
// Uso: `nextFolio(tx, 'CONTRACT', 2026)` dentro de una transacción
// hace UPSERT con increment atómico (Postgres lock por fila).
//
// Scope convencionales:
//   - 'CONTRACT'        → ARR-NNN-YYYY (year = año real, ej. 2026)
//   - 'QUOTATION'       → COT-NNNN     (year = 0, no rota anual)
//   - 'INVOICE_<serie>' → folio Int por serie SAT (year = 0)
model FolioSequence {
  scope     String   // 'CONTRACT' | 'QUOTATION' | 'INVOICE_<serie>'
  year      Int      // 2026, o 0 si la serie no rota anual
  ultimo    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([scope, year])
  @@map("folio_sequences")
}

// ──────────────────────────────────────────────────────────────────
// Catálogo de tasas, comisiones y GPS (single-row config)
// ──────────────────────────────────────────────────────────────────
//
// Antes: tasa 0.36, comisión 0.05, GPS $16k vivían como literales en
// el wizard del cliente y en leaseCalculator del server (defaults
// duplicados). Cambiar la tasa de la casa requería redeployar.
//
// Ahora: una sola fila con `clave='default'` que ADMIN/DIRECTOR
// pueden editar desde /admin/catalogo, leída por el cotizador en
// boot. Los presets de riesgo A/B/C viven en RiskPreset (tabla
// aparte porque son N filas, no 1).
//
// Diseño con clave estable en lugar de id auto-incremental: facilita
// `findUnique({ clave: 'default' })` sin necesidad de conocer el id
// generado, y permite (a futuro) tener múltiples perfiles de tasas
// (ej. clave='gobierno' con condiciones distintas).
model Catalog {
  clave                    String   @id  // 'default' (única por ahora)
  // Tasa anual ordinaria (decimal: 0.36 = 36%)
  tasaAnualDefault         Decimal  @db.Decimal(7, 4)
  tasaAnualMin             Decimal  @db.Decimal(7, 4)
  tasaAnualMax             Decimal  @db.Decimal(7, 4)
  // Comisión de apertura (decimal: 0.05 = 5%)
  comisionAperturaDefault  Decimal  @db.Decimal(7, 4)
  comisionAperturaMin      Decimal  @db.Decimal(7, 4)
  comisionAperturaMax      Decimal  @db.Decimal(7, 4)
  // GPS — monto absoluto en MXN; suele ser único de instalación
  gpsMontoDefault          Decimal  @db.Decimal(12, 2)
  gpsFinanciableDefault    Boolean  @default(true)
  // Multiplicador moratorio sobre la tasa ordinaria (CLAUDE.md §4.9)
  // Default 2.0 → 36% ord. = 72% mor. Editable por si Inyecta cambia
  // política comercial (ej. 1.5× para clientes preferentes).
  tasaMoratoriaMultiplier  Decimal  @db.Decimal(4, 2) @default(2.0)
  updatedAt                DateTime @updatedAt
  updatedById              String?  // user.id que editó la última vez

  @@map("catalog")
}

// Presets de depósito y enganche por nivel de riesgo (A/B/C). Antes
// duplicados en client/src/pages/operacionNuevo/constants.ts y en
// server/src/services/leaseCalculator.ts:411-413.
//
// Una fila por nivel. ADMIN/DIRECTOR puede ajustar los porcentajes;
// el visor de opciones (generarOpcionesRiesgo) lee desde aquí.
model RiskPreset {
  nivel                String   @id  // 'A' | 'B' | 'C'
  nombre               String           // 'Riesgo bajo' | 'medio' | 'alto'
  // PURO: enganche (típicamente 0), depósito (= valor residual display)
  engachePuroPct       Decimal  @db.Decimal(7, 4) @default(0)
  depositoPuroPct      Decimal  @db.Decimal(7, 4)
  // FINANCIERO: enganche y depósito independientes
  engancheFinPct       Decimal  @db.Decimal(7, 4)
  depositoFinPct       Decimal  @db.Decimal(7, 4)
  orden                Int      @default(0)  // 1, 2, 3 para ordenar UI
  updatedAt            DateTime @updatedAt
  updatedById          String?

  @@map("risk_presets")
}
