generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTENTICACIÓN Y USUARIOS
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nombre    String
  apellidos String
  rol       UserRole @default(ANALISTA)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cotizaciones  Quotation[]
  contratos     Contract[]
  pagosRegistrados Payment[]
  notas         Note[]
  documentosSubidos ContractDocument[]
  notificaciones Notificacion[]

  @@map("users")
}

enum UserRole {
  ADMIN
  DIRECTOR
  ANALISTA
  COBRANZA
  OPERACIONES
  LEGAL          // CLAUDE.md §2 — recibe notificaciones de SOLICITUD_*
}

// ============================================================
// CLIENTES
// ============================================================

model Client {
  id              String     @id @default(cuid())
  tipo            ClientType
  // Persona Física
  nombre          String?
  apellidoPaterno String?
  apellidoMaterno String?
  curp            String?
  // Persona Moral
  razonSocial     String?
  // Compartidos
  rfc             String?    @unique
  email           String?
  telefono        String?
  // Domicilio fiscal
  calle           String?
  numExterior     String?
  numInterior     String?
  colonia         String?
  municipio       String?
  ciudad          String?
  estado          String?
  cp              String?
  // Domicilio de operación (puede diferir del fiscal)
  calleOp         String?
  numExteriorOp   String?
  numInteriorOp   String?
  coloniaOp       String?
  municipioOp     String?
  ciudadOp        String?
  estadoOp        String?
  cpOp            String?
  // PM específicos
  actaConstitutiva     String?
  registroPublico      String?
  representanteLegal   String?
  // Metadata
  sector          String?
  actividadEconomica String?
  activo          Boolean  @default(true)
  // Portal del Arrendatario (acceso vía token único)
  portalToken     String?  @unique
  portalUltimoAcceso DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  documentos    ClientDocument[]
  avales        Guarantor[]
  socios        Shareholder[]
  cotizaciones  Quotation[]
  contratos     Contract[]
  notas         Note[]
  facturas      Invoice[]

  @@map("clients")
}

enum ClientType {
  PFAE
  PM
}

model ClientDocument {
  id          String         @id @default(cuid())
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tipo        String         // e.g. "INE", "CSF", "ESTADOS_FINANCIEROS"
  nombre      String         // nombre descriptivo
  requerido   Boolean        @default(true)
  estado      DocumentStatus @default(PENDIENTE)
  archivoUrl  String?
  fechaRecepcion DateTime?
  fechaVencimiento DateTime?
  observaciones String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("client_documents")
}

enum DocumentStatus {
  PENDIENTE
  RECIBIDO
  VENCIDO
  RECHAZADO
}

model Guarantor {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nombre          String
  apellidoPaterno String
  apellidoMaterno String?
  rfc             String?
  curp            String?
  telefono        String?
  email           String?
  domicilio       String?
  relacion        String?  // relación con el solicitante
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  documentos GarantorDocument[]

  @@map("guarantors")
}

model GarantorDocument {
  id          String         @id @default(cuid())
  guarantorId String
  guarantor   Guarantor      @relation(fields: [guarantorId], references: [id], onDelete: Cascade)
  tipo        String
  nombre      String
  estado      DocumentStatus @default(PENDIENTE)
  archivoUrl  String?
  fechaRecepcion DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("guarantor_documents")
}

model Shareholder {
  id              String  @id @default(cuid())
  clientId        String
  client          Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nombre          String
  apellidoPaterno String
  apellidoMaterno String?
  rfc             String?
  porcentaje      Decimal // porcentaje de participación accionaria
  esRepLegal      Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("shareholders")
}

// ============================================================
// CATÁLOGOS
// ============================================================

model AssetCategory {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  productos   String?  // ejemplos de productos (texto)
  tipoSeguro  String?  // tipo de cobertura requerida
  requiereGPS Boolean  @default(false)
  activo      Boolean  @default(true)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())

  cotizaciones Quotation[]
  contratos    Contract[]

  @@map("asset_categories")
}

// ============================================================
// COTIZACIONES
// ============================================================

model Quotation {
  id              String         @id @default(cuid())
  folio           String         @unique
  clientId        String?
  client          Client?        @relation(fields: [clientId], references: [id])
  nombreCliente   String         // puede ser prospecto sin client registrado
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  categoriaId     String?
  categoria       AssetCategory? @relation(fields: [categoriaId], references: [id])

  // Datos del bien
  bienDescripcion String?
  bienMarca       String?
  bienModelo      String?
  bienAnio        Int?
  bienNuevo       Boolean        @default(true)
  bienNumSerie    String?

  // Parámetros financieros
  producto        LeaseType
  valorBien       Decimal        // sin IVA
  valorBienIVA    Decimal?       // con IVA (calculado)
  plazo           Int            // meses (12-48)
  tasaAnual       Decimal        // e.g. 0.36
  nivelRiesgo     RiskLevel      @default(A)

  // Montos calculados
  enganche           Decimal   @default(0)
  enganchePorcentaje  Decimal   @default(0)
  depositoGarantia       Decimal   @default(0)
  depositoGarantiaPct    Decimal   @default(0)
  comisionApertura       Decimal   @default(0)
  comisionAperturaPct    Decimal   @default(0.05)
  comisionAperturaFinanciada Boolean @default(true)
  rentaInicial           Decimal   @default(0)
  gpsInstalacion         Decimal   @default(0)
  gpsFinanciado          Boolean   @default(true)
  seguroAnual            Decimal   @default(0)
  seguroFinanciado       Boolean   @default(true)
  valorResidual          Decimal   @default(0)
  valorResidualPct       Decimal   @default(0)

  // Resultados
  montoFinanciar    Decimal?
  rentaMensual      Decimal?
  rentaMensualIVA   Decimal?
  totalRentas       Decimal?
  totalPagar        Decimal?
  ganancia          Decimal?

  // Estado
  estado          QuotationStatus @default(VIGENTE)
  fechaCotizacion DateTime        @default(now())
  vigenciaHasta   DateTime?
  observaciones   String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  opciones  QuotationOption[]
  contrato  Contract?

  @@map("quotations")
}

enum LeaseType {
  PURO
  FINANCIERO
}

enum RiskLevel {
  A  // bajo - 16%
  B  // medio - 21%
  C  // alto - 26%
}

enum QuotationStatus {
  VIGENTE
  VENCIDA
  APROBADA
  RECHAZADA
  CONVERTIDA  // se convirtió en contrato
}

model QuotationOption {
  id            String    @id @default(cuid())
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  nombre        String    // "Opción A - Riesgo bajo", etc.
  producto      LeaseType
  nivelRiesgo   RiskLevel
  enganche      Decimal
  rentaInicial  Decimal
  depositoGarantia  Decimal
  rentaMensualIVA   Decimal
  valorResidual     Decimal
  totalPagar        Decimal
  ganancia          Decimal
  descripcion   String?   // descripción de la estructura

  @@map("quotation_options")
}

// ============================================================
// CONTRATOS
// ============================================================

model Contract {
  id              String          @id @default(cuid())
  folio           String          @unique  // e.g. ARR-001-2026
  quotationId     String?         @unique
  quotation       Quotation?      @relation(fields: [quotationId], references: [id])
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id])
  userId          String          // analista que registró
  user            User            @relation(fields: [userId], references: [id])
  categoriaId     String?
  categoria       AssetCategory?  @relation(fields: [categoriaId], references: [id])

  // Pipeline
  etapa           ContractStage   @default(SOLICITUD)
  etapaFecha      DateTime        @default(now())
  comiteResolucion String?        // APROBADO, APROBADO_CONDICIONES, RECHAZADO

  // Datos del bien
  bienDescripcion String
  bienMarca       String?
  bienModelo      String?
  bienAnio        Int?
  bienNumSerie    String?
  bienEstado      String?         // nuevo/seminuevo
  proveedor       String?

  // Parámetros financieros
  producto        LeaseType
  valorBien       Decimal
  valorBienIVA    Decimal
  plazo           Int
  tasaAnual       Decimal
  tasaMoratoria   Decimal?        // default: 2x tasa ordinaria
  nivelRiesgo     RiskLevel

  // Montos
  enganche              Decimal  @default(0)
  depositoGarantia      Decimal  @default(0)
  comisionApertura      Decimal  @default(0)
  rentaInicial          Decimal  @default(0)
  gpsInstalacion        Decimal  @default(0)
  seguroAnual           Decimal  @default(0)
  valorResidual         Decimal  @default(0)
  montoFinanciar        Decimal
  rentaMensual          Decimal
  rentaMensualIVA       Decimal

  // Fechas
  fechaFirma            DateTime?
  fechaInicio           DateTime?    // fecha de primera renta
  fechaEntregaBien      DateTime?
  fechaVencimiento      DateTime?
  fechaTerminacion      DateTime?

  // Estado del contrato
  estatus         ContractStatus   @default(EN_PROCESO)
  motivoTerminacion String?

  // Opción al vencimiento
  opcionVencimiento EndOption?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  amortizacion    AmortizationEntry[]
  pagos           Payment[]
  seguros         InsurancePolicy[]
  gps             GPSDevice[]
  mantenimientos  MaintenanceRecord[]
  notas           Note[]
  stageHistory    StageHistory[]
  documentos      ContractDocument[]
  facturas        Invoice[]

  @@map("contracts")
}

model ContractDocument {
  id            String         @id @default(cuid())
  contractId    String
  contract      Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  etapa         ContractStage  // etapa donde se requiere el documento
  tipo          String         // p.ej. "CONTRATO_FIRMADO", "PAGARE", "ACTA_ENTREGA"
  nombre        String         // descripción humana
  requerido     Boolean        @default(true)
  estado        DocumentStatus @default(PENDIENTE)
  archivoUrl    String?
  archivoNombre String?
  fechaRecepcion DateTime?
  observaciones String?
  uploadedBy    String?
  uploadedByUser User?         @relation(fields: [uploadedBy], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("contract_documents")
}

enum ContractStage {
  SOLICITUD
  ANALISIS_CLIENTE
  ANALISIS_BIEN
  COMITE
  FORMALIZACION
  DESEMBOLSO
  ACTIVO
}

enum ContractStatus {
  EN_PROCESO    // aún en pipeline
  VIGENTE       // contrato activo
  VENCIDO       // pasó fecha de vencimiento sin formalizar cierre
  TERMINADO     // terminación normal
  RESCINDIDO    // rescisión por incumplimiento
  REESTRUCTURADO
}

enum EndOption {
  DEVOLUCION
  RENOVACION
  RESCATE        // Puro: paga valor residual
  OPCION_COMPRA  // Financiero: paga 2% simbólico
}

model StageHistory {
  id          String        @id @default(cuid())
  contractId  String
  contract    Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  etapa       ContractStage
  fecha       DateTime      @default(now())
  observacion String?
  usuarioId   String?

  @@map("stage_history")
}

// ============================================================
// AMORTIZACIÓN
// ============================================================

model AmortizationEntry {
  id            String   @id @default(cuid())
  contractId    String
  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  periodo       Int
  fechaPago     DateTime
  saldoInicial  Decimal
  intereses     Decimal  @default(0)  // solo financiero
  pagoCapital   Decimal  @default(0)  // solo financiero
  renta         Decimal
  iva           Decimal
  seguro        Decimal  @default(0)
  pagoTotal     Decimal
  saldoFinal    Decimal

  @@unique([contractId, periodo])
  @@map("amortization_entries")
}

// ============================================================
// PAGOS Y COBRANZA
// ============================================================

model Payment {
  id              String        @id @default(cuid())
  contractId      String
  contract        Contract      @relation(fields: [contractId], references: [id])
  userId          String?       // quien registró el pago
  user            User?         @relation(fields: [userId], references: [id])

  periodo         Int?          // número de renta que cubre
  tipo            PaymentType
  fechaPago       DateTime
  fechaVencimiento DateTime?

  montoRenta      Decimal       @default(0)
  montoIVA        Decimal       @default(0)
  montoSeguro     Decimal       @default(0)
  montoMoratorio  Decimal       @default(0)
  montoIVAMoratorio Decimal     @default(0)
  montoCapitalExtra Decimal     @default(0) // abono a capital (financiero)
  montoTotal      Decimal

  diasAtraso      Int           @default(0)
  referencia      String?       // referencia bancaria / comprobante
  observaciones   String?

  factura         Invoice?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Índices de performance:
  //   (contractId, periodo) — buscar el pago de un periodo concreto
  //     (cobranza /pay-status, conciliación, reportes de morosidad).
  //   (contractId, fechaPago) — listar pagos cronológicos por contrato
  //     (estado de cuenta, portal del arrendatario).
  //   (fechaPago) — reportes de cobranza por rango de fechas.
  @@index([contractId, periodo])
  @@index([contractId, fechaPago])
  @@index([fechaPago])
  @@map("payments")
}

// ============================================================
// CONCILIACIÓN BANCARIA
// ============================================================

model BankStatement {
  id           String            @id @default(cuid())
  banco        String                                       // BBVA, Santander, Banamex, ...
  cuenta       String?                                      // CLABE o nº cuenta
  fileName     String
  fechaInicio  DateTime?
  fechaFin     DateTime?
  totalAbonos  Decimal           @default(0)
  totalCargos  Decimal           @default(0)
  uploadedBy   String?
  createdAt    DateTime          @default(now())

  transacciones BankTransaction[]

  @@map("bank_statements")
}

model BankTransaction {
  id            String         @id @default(cuid())
  statementId   String
  statement     BankStatement  @relation(fields: [statementId], references: [id], onDelete: Cascade)

  fecha         DateTime
  descripcion   String
  referencia    String?
  monto         Decimal                                    // positivo = abono (depósito a Inyecta)
  tipo          String                                     // ABONO | CARGO

  // Conciliación
  matched       Boolean        @default(false)
  paymentId     String?                                    // referencia (sin FK estricto)
  matchScore    Int?                                       // 0-100 (qué tan confiable fue el match)
  matchedBy     String?                                    // userId o "AUTO"
  matchedAt     DateTime?

  createdAt     DateTime       @default(now())

  @@index([statementId])
  @@index([matched])
  @@map("bank_transactions")
}

// ============================================================
// FACTURACIÓN ELECTRÓNICA (CFDI 4.0)
// ============================================================

model Invoice {
  id             String        @id @default(cuid())
  // Vínculo
  paymentId      String?       @unique
  payment        Payment?      @relation(fields: [paymentId], references: [id])
  contractId     String
  contract       Contract      @relation(fields: [contractId], references: [id])
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])

  // CFDI
  tipo           InvoiceType   @default(INGRESO)        // INGRESO / EGRESO / PAGO
  serie          String        @default("A")
  folio          Int
  uuid           String?       @unique                  // SAT
  fechaTimbrado  DateTime?
  status         InvoiceStatus @default(BORRADOR)

  // Importes
  subtotal       Decimal
  iva            Decimal       @default(0)
  retenciones    Decimal       @default(0)
  total          Decimal

  // Datos receptor (snapshot al momento de timbrado)
  rfcReceptor    String
  nombreReceptor String
  usoCfdi        String        @default("G03")          // Gastos en general
  metodoPago     String        @default("PUE")
  formaPago      String        @default("03")           // Transferencia
  regimenFiscal  String        @default("601")

  // Archivos
  xmlUrl         String?
  pdfUrl         String?

  // Cancelación
  motivoCancelacion String?
  fechaCancelacion  DateTime?

  // Provider
  provider       String        @default("MOCK")         // MOCK | FACTURAMA | SW

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([contractId])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceType {
  INGRESO
  EGRESO
  PAGO
}

enum InvoiceStatus {
  BORRADOR
  TIMBRADO
  CANCELADO
  ERROR
}

enum PaymentType {
  RENTA_ORDINARIA
  RENTA_ADELANTADA
  ABONO_CAPITAL       // solo financiero
  LIQUIDACION_ANTICIPADA
  MORATORIO
  RENTA_EXTRAORDINARIA  // post-vencimiento sin formalizar
  ENGANCHE
  DEPOSITO_GARANTIA
  COMISION_APERTURA
  SEGURO
  GPS
  OTRO
}

// ============================================================
// SEGUROS
// ============================================================

model InsurancePolicy {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  aseguradora     String?  // "Seguros El Potosí", etc.
  numPoliza       String?
  tipoCobertura   String?
  montoAsegurado  Decimal?
  primaAnual      Decimal?
  fechaInicio     DateTime?
  fechaVencimiento DateTime?
  endosoPref      Boolean  @default(true)  // endoso preferente a Inyecta
  vigente         Boolean  @default(true)
  observaciones   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("insurance_policies")
}

// ============================================================
// GPS
// ============================================================

model GPSDevice {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  marca           String?
  modelo          String?
  numSerie        String?
  proveedor       String?
  fechaInstalacion DateTime?
  activo          Boolean  @default(true)
  costoInstalacion Decimal? @default(0)
  observaciones   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("gps_devices")
}

// ============================================================
// MANTENIMIENTO
// ============================================================

model MaintenanceRecord {
  id              String          @id @default(cuid())
  contractId      String
  contract        Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tipo            MaintenanceType
  fecha           DateTime
  descripcion     String?
  taller          String?         // agencia/taller
  costo           Decimal?        @default(0)
  comprobanteUrl  String?
  observaciones   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("maintenance_records")
}

enum MaintenanceType {
  PREVENTIVO
  CORRECTIVO
  REVISION_ANUAL
  REVISION_ATRASO   // revisión por atraso en pagos
  SINIESTRO
}

// ============================================================
// NOTAS / BITÁCORA
// ============================================================

model Note {
  id          String   @id @default(cuid())
  contractId  String?
  contract    Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  contenido   String
  tipo        NoteType @default(GENERAL)
  createdAt   DateTime @default(now())

  @@map("notes")
}

enum NoteType {
  GENERAL
  COBRANZA
  COMITE
  LEGAL
  MANTENIMIENTO
  ALERTA
}

// ============================================================
// BITÁCORA — auditoría PLD (cumplimiento regulatorio SOFOM)
// Todas las operaciones POST/PATCH/PUT/DELETE quedan registradas
// con usuario, IP, payload y timestamp para inspección de la CNBV.
// ============================================================

// ============================================================
// NOTIFICACIONES IN-APP
// CLAUDE.md §9 T9 — notificar siempre a ADMIN + ejecutivo;
// si la acción es SOLICITUD_*, también a LEGAL.
// ============================================================

model Notificacion {
  id          String   @id @default(cuid())
  userId      String                          // destinatario
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo        String                          // ej: "SOLICITUD_CREADA", "PAGO_REGISTRADO", "CONTRATO_VENCIDO"
  titulo      String                          // texto corto para listado
  mensaje     String                          // descripción legible
  entidad     String?                         // ej: "Contract", "Payment", "Quotation"
  entidadId   String?                         // id del recurso relacionado
  url         String?                         // deep-link al detalle (opcional)
  leida       Boolean  @default(false)
  leidaAt     DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, leida])
  @@index([userId, createdAt])
  // Composite (userId, leida, createdAt): combina las dos anteriores en
  // una sola lectura de índice para la query estrella de la campana
  // ("últimas N no leídas del usuario X ordenadas por fecha desc").
  @@index([userId, leida, createdAt])
  @@index([entidad, entidadId])
  @@map("notificaciones")
}

model Bitacora {
  id          String   @id @default(cuid())
  usuarioId   String?
  usuarioEmail String?            // snapshot del email al momento del evento
  usuarioRol  String?             // snapshot del rol
  metodo      String              // GET, POST, PATCH, PUT, DELETE
  ruta        String              // ej: "/api/contracts/abc123"
  entidad     String?             // ej: "Contract", "Payment"
  entidadId   String?             // id del recurso afectado (si aplica)
  accion      String              // verbo descriptivo: CREATE, UPDATE, DELETE, LOGIN, etc.
  payloadJson Json?               // body sanitizado (sin password ni tokens)
  responseStatus Int?             // 200, 201, 4xx, 5xx
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([usuarioId])
  @@index([entidad, entidadId])
  @@index([createdAt])
  // Composite (usuarioId, createdAt): timeline por usuario sin scan.
  // Útil para "actividad del usuario X en los últimos 30 días" del visor
  // de bitácora (filtros usuarioId + rango de fechas).
  @@index([usuarioId, createdAt])
  @@map("bitacora")
}
