{
  "name": "inyecta-arrendamiento-server",
  "version": "1.0.0",
  "description": "Sistema de Arrendamiento Inyecta - Backend",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:errorHandler": "tsx src/__verify__/errorHandler.verify.ts",
    "verify:health": "tsx src/__verify__/health.verify.ts",
    "verify:branding": "tsx src/__verify__/branding.verify.ts",
    "verify:email": "tsx src/__verify__/email.verify.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@prisma/client": "^6.9.0",
    "@types/archiver": "^7.0.0",
    "@types/multer": "^2.1.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "prisma": "^6.9.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
