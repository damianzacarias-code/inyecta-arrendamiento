# ─────────────────────────────────────────────────────────────────────
# Inyecta Arrendamiento — Variables de entorno
# ─────────────────────────────────────────────────────────────────────
# Copia este archivo a `.env` y rellena los valores.
# La validación se hace en server/src/config/env.ts (Zod).
# Si una variable requerida falta o es inválida, el server NO arranca.
# ─────────────────────────────────────────────────────────────────────

# ── Runtime ─────────────────────────────────────────────────────────
# NODE_ENV: development | test | staging | production
NODE_ENV=development

# Puerto HTTP del backend (1-65535)
PORT=3001

# ── Base de datos ───────────────────────────────────────────────────
# Debe empezar con postgres:// o postgresql://
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/inyecta_arrendamiento"

# ── Auth (JWT) ──────────────────────────────────────────────────────
# REQUERIDO. En production debe tener ≥32 caracteres y NO ser el de dev.
JWT_SECRET="cambiar-por-un-secreto-seguro-en-produccion"

# Duración del token. Formatos: 24h, 60m, 7d, o segundos numéricos.
JWT_EXPIRES_IN="24h"

# Password inicial del usuario admin que crea `npm run seed`.
# - En development es opcional (default 'admin123').
# - En production es OBLIGATORIA, ≥12 chars, y rechazamos triviales
#   (admin123, password, changeme, 123456789012).
# Se aplica SOLO la primera vez (upsert no sobrescribe password).
SEED_ADMIN_PASSWORD=

# ── Bitácora (auditoría PLD) ────────────────────────────────────────
# Por defecto sólo se loggean POST/PATCH/PUT/DELETE para no inflar la
# tabla. Pon true si quieres registrar también GET (debug/forense).
BITACORA_LOG_GETS=false

# ── CFDI 4.0 (timbrado) ─────────────────────────────────────────────
# CFDI_PROVIDER: MOCK | FACTURAMA | SW
# - MOCK: emite XML CFDI 4.0 conforme firmado falso (desarrollo/testing)
# - FACTURAMA: REST contra api.facturama.mx (sandbox o producción)
# - SW: stub explícito (no implementado aún)
CFDI_PROVIDER=MOCK

# Datos del emisor (requeridos para CFDI real, opcionales en MOCK)
CFDI_EMISOR_RFC=
CFDI_EMISOR_NOMBRE=
# Régimen fiscal SAT a 3 dígitos (ej: 601 = General Personas Morales)
CFDI_EMISOR_REGIMEN=
# Código postal del lugar de expedición a 5 dígitos
CFDI_LUGAR_EXPEDICION=

# ── Facturama (sólo si CFDI_PROVIDER=FACTURAMA) ─────────────────────
# Ambas credenciales son OBLIGATORIAS si el provider es FACTURAMA.
FACTURAMA_USER=
FACTURAMA_PASS=
# true → apisandbox.facturama.mx | false → api.facturama.mx
FACTURAMA_SANDBOX=true

# ── CORS ────────────────────────────────────────────────────────────
# Lista de orígenes permitidos separados por coma. Ej:
# CORS_ALLOWED_ORIGINS="https://app.inyecta.mx,https://admin.inyecta.mx"
# Si no se define, en development se permite localhost:5173 y :3000.
CORS_ALLOWED_ORIGINS=

# ── Extracción automática de PDFs (Claude Vision) ───────────────────
# EXTRACT_PROVIDER:
#   MOCK   → devuelve datos hardcoded por tipo (default, no requiere red).
#   CLAUDE → usa @anthropic-ai/sdk con tu API key. Requiere ANTHROPIC_API_KEY.
#
# Tipos soportados por el endpoint POST /api/extract:
#   CSF, INE, COMPROBANTE_DOMICILIO, FACTURA_BIEN, ACTA_CONSTITUTIVA
#
# Costo aproximado por documento (Claude Sonnet 4.5, input PDF ~3 páginas):
#   ~$0.012 USD ≈ $0.20 MXN.
EXTRACT_PROVIDER=MOCK

# Obtén tu key en https://console.anthropic.com → API Keys.
# Solo es OBLIGATORIA si EXTRACT_PROVIDER=CLAUDE.
ANTHROPIC_API_KEY=

# Opcional: override del modelo. Default: claude-sonnet-4-5-20250929.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── Círculo de Crédito ──────────────────────────────────────────────
# Clave de Otorgante (10 dígitos) asignada por Círculo de Crédito.
# Mientras se tramita la real, se permite la clave de pruebas
# '0000000000' SOLO en development/test/staging. En production
# el server NO arranca con esta clave — solicita la real antes
# de desplegar.
CIRCULO_CREDITO_CLAVE_OTORGANTE=0000000000

# Razón social tal como la registró Círculo de Crédito.
CIRCULO_CREDITO_NOMBRE_OTORGANTE="FSMP SOLUCIONES DE CAPITAL SA DE CV SOFOM ENR"

# ── Branding (datos públicos del emisor para PDFs y portal) ─────────
# Estos valores aparecen en cotizaciones, recibos, estados de cuenta,
# tablas de amortización y la página /portal/:token del arrendatario.
# Se exponen sin auth vía GET /api/config/branding.
# Cambian sólo si Inyecta muda razón social, oficinas o contacto.
BRAND_RAZON_SOCIAL="FSMP Soluciones de Capital, S.A. de C.V., SOFOM, E.N.R."
BRAND_NOMBRE_COMERCIAL="Inyecta"
BRAND_DIRECCION="Av. Sierra Vista 1305, Piso 4 Oficina 7, Col. Lomas del Tecnológico, C.P. 78215, San Luis Potosí, S.L.P."
BRAND_TELEFONOS="444-521-7204 / 444-521-6980"
BRAND_EMAIL="contacto@inyecta.com.mx"
BRAND_WEB="www.inyecta.com.mx"

# ── Datos bancarios para depósitos del cliente ──────────────────────
# El cliente arrendatario los lee en su portal y en el estado de cuenta
# que descarga. En production se exigen 18 dígitos numéricos en
# BANCO_CLABE (no se acepta el placeholder con "X").
BANCO_NOMBRE="BBVA México"
BANCO_CLABE="012-180-XXXXXXXXXX-X"
BANCO_BENEFICIARIO="FSMP Soluciones de Capital, S.A. de C.V., SOFOM, E.N.R."

# ── Email saliente (notificaciones espejo de la campana) ────────────
# EMAIL_PROVIDER controla el backend:
#   NOOP     → no envía nada (default seguro de fábrica). Las
#              notificaciones in-app (campana) siguen funcionando.
#   SMTP     → nodemailer + cualquier servidor SMTP. Compatible con
#              Gmail/Workspace, Outlook 365, Amazon SES (SMTP),
#              SendGrid SMTP, Mailgun, Postmark, Resend, Brevo, Zoho.
#   SENDGRID → SDK nativo (stub — pendiente integrar).
#   SES      → SDK AWS nativo (stub — usa SMTP a SES mientras tanto).
EMAIL_PROVIDER=NOOP

# Dirección "De:" del email. En production con provider != NOOP es
# obligatoria. Formato típico: "Inyecta <noreply@inyecta.com.mx>"
EMAIL_FROM=

# Cabecera Reply-To opcional. Si se omite, las respuestas van al EMAIL_FROM.
EMAIL_REPLY_TO=

# ── SMTP (sólo si EMAIL_PROVIDER=SMTP) ──────────────────────────────
# Ejemplos:
#   Gmail / Workspace:
#     SMTP_HOST=smtp.gmail.com   SMTP_PORT=587  SMTP_SECURE=false
#     SMTP_USER=usuario@inyecta.com.mx  SMTP_PASS=<App Password de 16 chars>
#   Outlook 365:
#     SMTP_HOST=smtp-mail.outlook.com  SMTP_PORT=587  SMTP_SECURE=false
#   Amazon SES (vía SMTP):
#     SMTP_HOST=email-smtp.us-east-1.amazonaws.com  SMTP_PORT=587  SMTP_SECURE=false
#   SendGrid (vía SMTP):
#     SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey  SMTP_PASS=<API key>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# true → puerto 465 (TLS implícito) | false → puerto 587 (STARTTLS, recomendado)
SMTP_SECURE=false
# true → exige STARTTLS aunque secure=false. Casi siempre dejar en true.
SMTP_REQUIRE_TLS=true

# URL pública del frontend. Se incluye en los links de los emails
# ("Ver detalle: https://app.inyecta.com.mx/operaciones/123").
FRONTEND_BASE_URL=http://localhost:5173
